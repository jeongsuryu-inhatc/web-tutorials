<%- include("partials/header") %>

<h1><%= title %></h1>

<% if (todos.length === 0) { %>
  <p>할 일이 없습니다.</p>
<% } else { %>
  <ul style="padding: 0;">
    <% todos.forEach(function (todo) { %>
      <li style="list-style: none; background: #FFF; border: 1px solid #E5E7EB;
                 border-radius: 8px; padding: 12px; margin: 8px 0;">
        <% if (todo.done) { %>
          <s style="color: #9CA3AF;"><%= todo.title %></s>
        <% } else { %>
          <%= todo.title %>
        <% } %>
      </li>
    <% }); %>
  </ul>
  <p style="color: #6B7280;">
    남은 할 일: <%= todos.filter(t => !t.done).length %>개
  </p>
<% } %>

<%- include("partials/footer") %>
