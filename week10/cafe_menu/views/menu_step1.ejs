<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>카페 메뉴</title>
  <style>
    body { font-family: 'Malgun Gothic', sans-serif; background: #F9FAFB; color: #1F2937; margin: 0; }
    main { max-width: 560px; margin: 40px auto; padding: 0 16px; }
    h1 { text-align: center; }
    .category { color: #92400E; margin: 20px 0 8px; font-size: 15px; font-weight: bold; }
    .item { background: #FFF; border: 1px solid #E5E7EB; border-radius: 8px;
            padding: 12px 16px; margin: 6px 0;
            display: flex; justify-content: space-between; align-items: center; }
    .price { color: #92400E; font-weight: bold; }
  </style>
</head>
<body>
  <main>
    <h1>☕ 카페 메뉴</h1>

    <% if (menus.length === 0) { %>
      <p>메뉴가 없습니다. init_db.js를 실행해 보세요.</p>
    <% } else { %>
      <%
        // 카테고리별로 묶어서 표시
        let currentCategory = "";
      %>
      <% menus.forEach(function (menu) { %>
        <% if (menu.category !== currentCategory) { currentCategory = menu.category; %>
          <div class="category"><%= currentCategory %></div>
        <% } %>
        <div class="item">
          <span><%= menu.name %></span>
          <span class="price"><%= menu.price.toLocaleString() %>원</span>
        </div>
      <% }); %>
    <% } %>
  </main>
</body>
</html>
