<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>카페 메뉴</title>
  <style>
    body { font-family: 'Malgun Gothic', sans-serif; background: #F9FAFB; color: #1F2937; margin: 0; }
    main { max-width: 560px; margin: 40px auto; padding: 0 16px; }
    h1 { text-align: center; }
    .add-form { display: flex; gap: 8px; background: #FFF; border: 1px solid #E5E7EB;
                border-radius: 8px; padding: 12px; }
    .add-form input[type="text"] { flex: 1; padding: 8px; border: 1px solid #E5E7EB; border-radius: 6px; }
    .add-form input[type="number"] { width: 90px; padding: 8px; border: 1px solid #E5E7EB; border-radius: 6px; }
    .add-form select { padding: 8px; border: 1px solid #E5E7EB; border-radius: 6px; }
    .add-form button { background: #92400E; color: #FFF; border: none; border-radius: 6px;
                       padding: 0 16px; cursor: pointer; }
    .category { color: #92400E; margin: 20px 0 8px; font-size: 15px; font-weight: bold; }
    .item { background: #FFF; border: 1px solid #E5E7EB; border-radius: 8px;
            padding: 12px 16px; margin: 6px 0;
            display: flex; align-items: center; gap: 10px; }
    .item .name { flex: 1; }
    .price { color: #92400E; font-weight: bold; }
    .edit-link { color: #6B7280; font-size: 13px; text-decoration: none; }
    .edit-link:hover { color: #92400E; }
  </style>
</head>
<body>
  <main>
    <h1>☕ 카페 메뉴</h1>

    <form class="add-form" method="POST" action="/menus">
      <input type="text" name="name" placeholder="메뉴 이름" required>
      <input type="number" name="price" placeholder="가격" min="0" required>
      <select name="category">
        <option>커피</option>
        <option>티</option>
        <option>디저트</option>
      </select>
      <button type="submit">추가</button>
    </form>

    <% let currentCategory = ""; %>
    <% menus.forEach(function (menu) { %>
      <% if (menu.category !== currentCategory) { currentCategory = menu.category; %>
        <div class="category"><%= currentCategory %></div>
      <% } %>
      <div class="item">
        <span class="name"><%= menu.name %></span>
        <span class="price"><%= menu.price.toLocaleString() %>원</span>
        <!-- [U] 수정 링크 -->
        <a class="edit-link" href="/menus/<%= menu.id %>/edit">수정</a>
      </div>
    <% }); %>
  </main>
</body>
</html>
